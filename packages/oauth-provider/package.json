{
  "name": "@reign-auth/oauth-provider",
  "version": "1.5.7-beta.1",
  "description": "An oauth provider plugin for Reign Auth",
  "type": "module",
  "license": "MIT",
  "homepage": "https://auth.reign-labs.com/docs/plugins/oauth-provider",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reign-Labs/reign-auth.git",
    "directory": "packages/oauth-provider"
  },
  "keywords": [
    "auth",
    "oauth",
    "typescript",
    "reign-auth"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint:package": "publint run --strict",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --project tsconfig.json",
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=istanbul"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./client": {
      "dev-source": "./src/client.ts",
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    },
    "./resource-client": {
      "dev-source": "./src/client-resource.ts",
      "types": "./dist/client-resource.d.mts",
      "default": "./dist/client-resource.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ],
      "client": [
        "./dist/client.d.mts"
      ],
      "resource-client": [
        "./dist/client-resource.d.mts"
      ]
    }
  },
  "dependencies": {
    "jose": "^6.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@reign-auth/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "reign-auth": "workspace:*",
    "listhen": "^1.9.0",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "@reign-auth/core": "workspace:*",
    "@reign-auth/utils": "workspace:*",
    "@reign-auth/fetch": "workspace:*",
    "reign-auth": "workspace:*",
    "reign-call": "workspace:*"
  }
}
