{
  "name": "@reign-auth/sso",
  "version": "1.5.7-beta.1",
  "description": "SSO plugin for Reign Auth",
  "type": "module",
  "license": "MIT",
  "homepage": "https://auth.reign-labs.com/docs/plugins/sso",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reign-Labs/reign-auth.git",
    "directory": "packages/sso"
  },
  "author": "Bereket Engida",
  "keywords": [
    "sso",
    "auth",
    "saml",
    "oauth",
    "oidc",
    "openid",
    "openid connect",
    "single sign on",
    "typescript",
    "reign-auth"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint:package": "publint run --strict",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --project tsconfig.json",
    "test": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=istanbul"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./client": {
      "dev-source": "./src/client.ts",
      "types": "./dist/client.d.mts",
      "default": "./dist/client.mjs"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/index.d.mts"
      ],
      "client": [
        "./dist/client.d.mts"
      ]
    }
  },
  "dependencies": {
    "@reign-auth/utils": "workspace:*",
    "@reign-auth/fetch": "workspace:*",
    "fast-xml-parser": "^5.5.7",
    "jose": "^6.1.3",
    "samlify": "^2.10.2",
    "tldts": "^6.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@reign-auth/core": "workspace:*",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.6",
    "reign-auth": "workspace:*",
    "reign-call": "workspace:*",
    "body-parser": "^2.2.2",
    "express": "^5.2.1",
    "oauth2-mock-server": "^8.2.2",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "@reign-auth/core": "workspace:*",
    "@reign-auth/utils": "workspace:*",
    "reign-auth": "workspace:*",
    "reign-call": "workspace:*"
  }
}
