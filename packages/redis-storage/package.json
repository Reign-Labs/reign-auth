{
  "name": "@reign-auth/redis-storage",
  "version": "1.5.7-beta.1",
  "description": "Redis storage for Reign Auth secondary storage",
  "type": "module",
  "license": "MIT",
  "homepage": "https://auth.reign-labs.com/docs/storage",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Reign-Labs/reign-auth.git",
    "directory": "packages/redis-storage"
  },
  "keywords": [
    "auth",
    "redis",
    "storage",
    "typescript",
    "reign-auth"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint:package": "publint run --strict",
    "lint:types": "attw --profile esm-only --pack .",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "dev-source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "peerDependencies": {
    "@reign-auth/core": "workspace:*",
    "ioredis": "^5.0.0"
  },
  "devDependencies": {
    "@reign-auth/core": "workspace:*",
    "@types/node": "^25.3.2",
    "ioredis": "^5.9.3",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:vitest"
  }
}
